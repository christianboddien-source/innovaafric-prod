# Copia este archivo a .env y rellena los valores.
# ⚠ .env NO se sube nunca a Git. El .gitignore de esta carpeta ya lo excluye.

# Credenciales de AliExpress Open Platform.
# El App Secret es como la contraseña de la tienda: solo aquí, nunca en el
# navegador, nunca en el chat, nunca en un commit.
AE_APP_KEY=
AE_APP_SECRET=

# Id de seguimiento de afiliado (opcional, para comisiones).
AE_TRACKING_ID=

# Orígenes autorizados a usar el proxy, separados por comas.
# Sin esto, cualquier web podría gastar tu cuota de AliExpress.
ALLOWED_ORIGINS=https://www.xendershop.com,https://xendershop.com,https://christianboddien-source.github.io

# Milisegundos que se guarda en caché cada búsqueda (10 min por defecto).
CACHE_TTL_MS=600000

# Railway lo inyecta solo. En Docker/IONOS se deja en 3000.
PORT=3000
