# ═══════════════════════════════════════════════════════════════════════════
#  Caddy — servidor web de InnovaAFRIC en IONOS
#
#  Caddy saca y renueva los certificados TLS solo, sin configurar nada. Por
#  eso se elige frente a Nginx: es una cosa menos que mantener.
#
#  ⚠ ANTES DE ARRANCAR: los registros A de cada dominio deben apuntar ya a la
#    IP del servidor. Caddy pide el certificado al arrancar y si el DNS no
#    resuelve, falla.
# ═══════════════════════════════════════════════════════════════════════════

{
	# Cambiar por el correo real: aquí avisa Let's Encrypt si un certificado
	# va a caducar sin renovarse.
	email christianboddien@gmail.com
}

# ── XenderShop ─────────────────────────────────────────────────────────────
www.xendershop.com, xendershop.com {
	root * /srv/xendershop
	file_server
	encode gzip zstd

	# El proxy de AliExpress se sirve bajo el mismo dominio. Así el navegador
	# no hace peticiones entre dominios y CORS deja de ser un problema.
	handle /api/aliexpress/* {
		uri strip_prefix /api
		reverse_proxy aliexpress-proxy:3000
	}

	header {
		# Cabeceras de seguridad básicas.
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "SAMEORIGIN"
	}
}

