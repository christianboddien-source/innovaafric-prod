# ── InnovaAFRIC (portada del ecosistema) ───────────────────────────────────
# Va LA ÚLTIMA en la migración de dominios: api.innovaafric.com apunta hoy a
# Railway y hay enrutado de correo vivo. Hay que recrear el registro `api`
# antes de mover este dominio.
www.innovaafric.com, innovaafric.com {
	root * /srv/innovaafric
	file_server
	encode gzip zstd
}
